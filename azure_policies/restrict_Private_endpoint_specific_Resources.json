
{
  "properties": {
    "displayName": "Allow Private Endpoints only for Storage, Key Vault, and Cosmos DB",
    "policyType": "Custom",
    "mode": "All",
    "description": "Deny private endpoints unless target is Storage, Key Vault, or Cosmos DB",
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/privateEndpoints"
          },
          {
            "not": {
              "anyOf": [
                {
                  "allOf": [
                    {
                      "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId",
                      "contains": "Microsoft.Storage/storageAccounts"
                    },
                    {
                      "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].groupIds[*]",
                      "in": [ "blob", "file", "queue", "table" ]
                    }
                  ]
                },
                {
                  "allOf": [
                    {
                      "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId",
                      "contains": "Microsoft.KeyVault/vaults"
                    },
                    {
                      "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].groupIds[*]",
                      "equals": "vault"
                    }
                  ]
                },
                {
                  "allOf": [
                    {
                      "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId",
                      "contains": "Microsoft.DocumentDB/databaseAccounts"
                    },
                    {
                      "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].groupIds[*]",
                      "in": [ "Sql", "MongoDB", "Cassandra", "Table", "Gremlin" ]
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}
